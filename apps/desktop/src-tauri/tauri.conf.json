{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Roughcut Stdio",
  "version": "0.1.0",
  "identifier": "com.roughcutstdio.desktop",
  "build": {
    "beforeDevCommand": "npm run dev --workspace @roughcut-stdio/desktop",
    "beforeBuildCommand": "npm run build --workspace @roughcut-stdio/desktop",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Roughcut Stdio",
        "width": 1440,
        "height": 960,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$APPDATA/generated/**",
            "$APPCACHE/**",
            "$RESOURCE/**",
            "$HOME/**"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "./.runtime-bundle/services/": "services/",
      "./.runtime-bundle/fixtures/": "fixtures/",
      "./.runtime-bundle/runtime/": "runtime/"
    },
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
